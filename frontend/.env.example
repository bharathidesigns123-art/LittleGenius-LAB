# Azure Blob Storage Configuration
# Get these values from your Azure Portal Storage Account
# 1. Storage Account Name: Settings > Access Keys > Storage account name
# 2. Container Name: Data storage > Containers > Create/use a container name
# 3. SAS Token: Shared access signature > Generate SAS and connection string

NEXT_PUBLIC_AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
NEXT_PUBLIC_AZURE_STORAGE_CONTAINER_NAME=littlegenius-images
NEXT_PUBLIC_AZURE_SAS_TOKEN=your-sas-token-here
