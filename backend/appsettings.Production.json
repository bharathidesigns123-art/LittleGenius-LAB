{
  "ConnectionStrings": {
    "SqlServer": ""
  },
  "Email": {
    "Host": "${EMAIL_HOST}",
    "Port": 587,
    "User": "${EMAIL_USER}",
    "Pass": "${EMAIL_PASS}",
    "FromEmail": "${EMAIL_FROM}",
    "FromName": "LittleGenius LAB",
    "EnableSsl": true
  },
  "Sms": {
    "Provider": "${SMS_PROVIDER}",
    "ApiKey": "${SMS_API_KEY}",
    "SenderId": "${SMS_SENDER_ID}",
    "TwilioAccountSid": "${TWILIO_ACCOUNT_SID}",
    "TwilioAuthToken": "${TWILIO_AUTH_TOKEN}",
    "TwilioFrom": "${TWILIO_FROM}",
    "Msg91TemplateId": "${MSG91_TEMPLATE_ID}"
  },
  "Notifications": {
    "AdminEmail": "${ADMIN_NOTIFICATION_EMAIL}",
    "SendLoginAlerts": false,
    "MaxRetryAttempts": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
